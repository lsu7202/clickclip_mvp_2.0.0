# ============================================================
# ClickClip 2.0.0 — environment (docker compose 단일 관리)
# 복사: cp .env.example .env  후 키 채우기
# 경로는 모두 "컨테이너 내부" 절대경로 (호스트 경로 아님)
# ============================================================

# ---- 공통 캔버스 ----
CANVAS_WIDTH=1080
CANVAS_HEIGHT=1920
DEFAULT_STILL_US=3000000

# ---- backend ----
PORT=4000
AI_SERVER_URL=http://ai_server:8000

# ---- ai: Gemini (장면분할·의미분리·전사번역) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- ai: Typecast (TTS) ----
TYPECAST_API_KEY=
TYPECAST_MODEL=ssfm-v30
TYPECAST_OUTPUT_FORMAT=mp3
TTS_SPEED=1.0
# 자막1 TTS 앞뒤 무음 제거(A). 줄 시작/끝 dead air 제거 → 내레이션 타이트. 기본 on.
# 임계값은 보수적으로(-60dB): TTS 진짜 무음은 -80dB 미만이라 말끝 감쇠를 안 자름.
TTS_TRIM_SILENCE=true
TTS_SILENCE_THRESHOLD_DB=-60
# 보이스맵 (JSON 배열). ai/backend 공유
TYPECAST_VOICES=[{"voice_id":"tc_voice_minsu","name":"민수"},{"voice_id":"tc_voice_yuna","name":"유나"}]
TYPECAST_LANG_MAP={"ko":"kor","ja":"jpn"}

# ---- ai: fal.ai (AI 미디어 4모델) ----
FAL_KEY=
FAL_MODEL_IMAGE_T2I=fal-ai/flux-pro/v1.1-ultra
FAL_MODEL_IMAGE_REF=fal-ai/nano-banana/edit
FAL_MODEL_VIDEO_T2V=fal-ai/wan-25-preview/text-to-video
FAL_MODEL_VIDEO_I2V=fal-ai/wan-25-preview/image-to-video

# ---- backend: 검색 ----
GIPHY_API_KEY=
GIPHY_LIMIT=24
SERPAPI_KEY=

# ---- ai: Google Video Intelligence (샷 감지 전용) ----
GOOGLE_APPLICATION_CREDENTIALS=/run/gcp/credentials.json
GCP_PROJECT=
STT_LOCATION=us-central1
STT_MODEL=chirp_2

# ---- 리소스 폴더 (컨테이너 내부 경로; bind mount는 compose에서) ----
MY_TEMPLATES_DIR=/resources/my_templates
MY_SAMPLES_DIR=/resources/my_samples
MY_STYLES_DIR=/resources/my_styles
MY_VOICES_DIR=/resources/my_voices

# ---- CapCut export ----
CAPCUT_DRAFT_ROOT=/capcut_drafts
# 실제 CapCut 드래프트 폴더(호스트 절대경로). compose 마운트 + draft JSON 경로에 사용.
# 맥 예: /Users/<you>/Movies/CapCut/User Data/Projects/com.lveditor.draft
CAPCUT_DRAFT_ROOT_HOST=/Users/me/Movies/CapCut/User Data/Projects/com.lveditor.draft
CAPCUT_TEMPLATE_DIR=/resources/capcut_template
CAPCUT_FONT_PATH=/resources/fonts/font.ttf

# ---- workspace (생성 에셋 저장) ----
WORKSPACE_DIR=/workspace

# ---- frontend ----
# 브라우저에서 접근하는 backend 주소
VITE_BACKEND_URL=http://localhost:4000
